@using RecipesApp.Core.Models
@model RecipesListViewModel

@{
    ViewData["Title"] = "Всички рецепти в категория \"" + TempData["CategoryName"] + "\"";
}

<p class="linksAboveHeader">
    <a asp-controller="Home" asp-action="Index">Начало</a> >
    <a asp-controller="Categories" asp-action="ByName" asp-route-name="@TempData["CategoryName"]">@TempData["CategoryName"]</a>
</p>

<header id="singleCategory">
    <section class="recipe-container">
        <article class="recipe-title">
            <p>@TempData["CategoryName"]</p>
        </article>
        <article class="flex-recipe-container">
            <article class="recipe-img">
                <img src="@TempData["CategoryImage"]" class="img-fluid w-80" />
            </article>
            <article class="recipe-info">
                <ul>
                    <li>Рецепти в категорията: @Model.RecipesCount</li>
                </ul>
            </article>
        </article>
        <span id="singleRecipe-categoryName" style="display:none">@TempData["CategoryName"]</span>
    </section>
</header>

@if (Model.RecipesCount > 0)
{
    <partial name="_PageTitle" />
}

<partial name="_RecipesPartial" model="@Model" />

@if (Model.Recipes.Count() > Model.ItemsPerPage)
{
    <partial name="_PagingPartial" model="@Model" />
}