@using RecipesApp.Core.Models
@model RecipeInputModel

@{
    ViewData["Title"] = "Рецепти";
    var categoryItems = Model.Categories.Select(x => new SelectListItem { Value = x.Id.ToString(), Text = x.Name });
}

<form method="post" id="recipeForm" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Name" class="form-label">Заглавие на рецептата</label>
        <input asp-for="Name" class="form-control">
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Instructions" class="form-label">Начин на приготвяне</label>
        <textarea asp-for="Instructions" class="form-control" rows="10"></textarea>
        <span asp-validation-for="Instructions" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PreparationTime" class="form-label">Време за приготвяне /минути/</label>
        <input asp-for="PreparationTime" class="form-control" />
        <span asp-validation-for="PreparationTime" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CookingTime" class="form-label">Време за готвене /минути/</label>
        <input asp-for="CookingTime" class="form-control" />
        <span asp-validation-for="CookingTime" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PortionsCount" class="form-label">Порции</label>
        <input asp-for="PortionsCount" class="form-control" />
        <span asp-validation-for="PortionsCount" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CategoryId" class="form-label">Категория</label>
        <select asp-for="CategoryId" asp-items="categoryItems" class="form-control">
            <option value="0">Изберете категория</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Image" class="form-label">Снимка</label>
        <input asp-for="Image" class="form-control-file" />
        <span asp-validation-for="Image" class="text-danger"></span>
    </div>

    <div id="IngredientsContainer" class="row">
    </div>

    <button id="addIngredient" class="btn btn-info">Добави съставка</button>

    <input type="submit" value="Изпрати" class="btn btn-primary" />

</form>

@section Scripts {
    <script src="~/js/ingredients.js" asp-append-version="true"></script>
}
