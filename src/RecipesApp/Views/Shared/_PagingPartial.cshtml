@using RecipesApp.Core.Models
@model PagingViewModel

<section>
    <article class="pagination">
        @if (Model.HasPreviousPage)
        {
            <a asp-action="All" asp-route-id="@Model.PreviousPageNumber">&laquo; Предишна</a>
        }
        @for (int i = Model.PageNumber - 4; i < Model.PageNumber; i++)
        {
            if (i > 0)
            {
            <a asp-action="All" asp-route-id="@i">@i</a>
            }
        }
        <a asp-action="All" asp-route-id="@Model.PageNumber" class="active">@Model.PageNumber</a>
        @for (int i = Model.PageNumber + 1; i <= Model.PageNumber + 4; i++)
        {
            if (i <= Model.PagesCount)
            {
                <a asp-action="All" asp-route-id="@i">@i</a>
            }
        }
        @if (Model.HasNextPage)
        {
            <a asp-action="All" asp-route-id="@Model.NextPageNumber">Следваща &raquo;</a>
        }
    </article>
</section>