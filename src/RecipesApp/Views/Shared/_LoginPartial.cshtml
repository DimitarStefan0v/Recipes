@using Microsoft.AspNetCore.Identity
@using RecipesApp.Infrastructure.Data.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <a class="userContainer asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage"><i class="fa-solid fa-user"></i></a>

    <form class="logOutContainer" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
        <button type="submit">Излез</button>
    </form>

}
else
{
    <a class="userContainer" asp-area="Identity" asp-page="/Account/Login"><i class="fa-solid fa-user"></i>Вход</a>
}
