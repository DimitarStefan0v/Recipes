@using Microsoft.AspNetCore.Identity
@using RecipesApp.Infrastructure.Data.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager


@if (SignInManager.IsSignedIn(User))
{
    <a id="accInfo" class="navbar-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage"><i class="fa-regular fa-user"></i></a>
    <form id="logOutForm" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
        <button type="submit" id="logOutBtn">ИЗЛЕЗ</button>
    </form>

}
else
{
    <a id="logIn"  class="navbar-link" asp-area="Identity" asp-page="/Account/Login">Вход</a>
}
