@using Microsoft.AspNetCore.Identity
@using RecipesApp.Infrastructure.Data.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager


<ul id="acc-links">
    @if (SignInManager.IsSignedIn(User))
    {
        <li>
            <a id="accountDetails" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Акаунт</a>
        </li>
        <li>
            <form id="logOutForm" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" id="logOutBtn">ИЗЛЕЗ</button>
            </form>
        </li>
    }
    else
    {
        <li>
            <a id="logIn" asp-area="Identity" asp-page="/Account/Login">Вход</a>
        </li>
    }
</ul>