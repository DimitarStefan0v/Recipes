@using RecipesApp.Core.Models
@model RecipesListViewModel

@{
    ViewData["Title"] = "Любими рецепти";
}

<partial name="_PageTitle" />

<p class="linksAboveHeader">
    <a asp-controller="Home" asp-action="Index">Начало</a> >
    <a asp-controller="Recipes" asp-action="Favorites">Любими</a>
</p>

@if (Model.RecipesCount == 0)
{
    <p id="favorites-msg">
        В момента нямате рецепти добавени към любими.
        Тук може да разгледате всички рецепти подредени от <a asp-controller="Recipes" asp-action="All">най-нови към най-стари.</a>
        Или тук може да потърсите рецепти по дадена <a asp-controller="Categories" asp-action="Index">карегория.</a>
        Можете също така да потърсите дадена рецепта по избрани <a asp-controller="SearchRecipes" asp-action="Index">съставки.</a>
    </p>
}
else
{
    <partial name="_RecipesPartial" model="@Model" />

    <partial name="_PagingPartial" model="@Model" />
}