@using RecipesApp.Core.Models
@model RecipesListViewModel

@{
    ViewData["Title"] = "Всички рецепти";
}

<partial name="_PageTitle" />

<p class="linksAboveHeader">
    <a asp-controller="Home" asp-action="Index">Начало</a> >
    <a asp-controller="Categories" asp-action="Index">Категории</a>
    <span>В момента в базата ни са добавени @Model.RecipesCount рецепти</span>
</p>

<partial name="_RecipesPartial" model="@Model" />

@if (Model.RecipesCount > 0 )
{
    <partial name="_PagingPartial" model="@Model" />
}
